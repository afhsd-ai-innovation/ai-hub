<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>District AI Assistant Library</title>
    <!-- Tailwind CSS for styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;  
            overflow: hidden;
        }
        .line-clamp-1 {
            display: -webkit-box;
            -webkit-line-clamp: 1;
            -webkit-box-orient: vertical;  
            overflow: hidden;
        }
        /* Custom scrollbar for category list */
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* Smooth transitions for loading states */
        #loading-screen { transition: opacity 0.3s ease-out; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen">

    <div id="app" class="max-w-6xl mx-auto p-4 md:p-8">
        <!-- Loading State -->
        <div id="loading-screen" class="fixed inset-0 flex flex-col items-center justify-center bg-slate-50 z-50">
            <i data-lucide="loader-2" class="w-10 h-10 animate-spin text-blue-600 mb-4"></i>
            <p class="font-medium text-slate-600 animate-pulse">Syncing with District Library...</p>
        </div>

        <!-- Error State (Hidden by default) -->
        <div id="error-container" class="hidden mb-6 p-6 bg-red-50 border border-red-200 rounded-xl flex flex-col gap-4 text-red-700 shadow-sm transition-all animate-in fade-in zoom-in-95 duration-300">
            <div class="flex items-start gap-4">
                <i data-lucide="alert-circle" class="w-6 h-6 shrink-0 mt-0.5"></i>
                <div>
                    <p class="text-base font-bold">Database Connection Failed</p>
                    <p id="error-message" class="text-sm opacity-90 leading-relaxed mt-1"></p>
                    <div class="mt-4 p-3 bg-white/50 rounded-lg border border-red-100 text-xs font-mono">
                        <strong>Troubleshooting Checklist:</strong>
                        <ul class="list-disc ml-4 mt-2 space-y-1">
                            <li>Is your Google Sheet <strong>"Published to Web"</strong> as a CSV?</li>
                            <li>Is <strong>"Restrict access to domain"</strong> definitely unchecked?</li>
                            <li>Your school network may be blocking the data proxies we use to bypass browser security.</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="flex justify-end pt-2">
                <button onclick="fetchData()" class="flex items-center gap-2 px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white rounded-xl text-sm font-bold transition-all shadow-md active:scale-95">
                    <i data-lucide="refresh-cw" class="w-4 h-4" id="retry-icon"></i>
                    Retry Connection
                </button>
            </div>
        </div>

        <header class="mb-8 flex flex-col md:flex-row md:items-start justify-between gap-4">
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
                    District AI Assistant Library
                </h1>
                <p class="mt-2 text-slate-600 max-w-2xl">
                    Browse and access specialized AI tools developed for district staff and students. 
                    Click any card to launch the assistant.
                </p>
            </div>
            <div class="flex flex-col gap-2 min-w-fit">
                <a href="https://sites.google.com/aguafria.org/thinkai" target="_blank" class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-xl font-bold shadow-lg shadow-blue-200 transition-all hover:-translate-y-0.5 whitespace-nowrap">
                    <i data-lucide="plus" class="w-5 h-5"></i>
                    Create my own AI assistant
                </a>
                <a href="#" target="_blank" class="inline-flex items-center justify-center gap-2 bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 px-5 py-2.5 rounded-xl font-bold shadow-sm transition-all hover:-translate-y-0.5 whitespace-nowrap">
                    <i data-lucide="play" class="w-5 h-5 fill-current text-blue-600"></i>
                    Create AI Assistant: How-to Video
                </a>
            </div>
        </header>

        <!-- Filters Section -->
        <div class="space-y-6 mb-8">
            <div class="flex flex-col md:flex-row gap-4 items-stretch">
                <div class="relative flex-grow w-full">
                    <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 w-5 h-5"></i>
                    <input
                        id="search-input"
                        type="text"
                        placeholder="Search by name or description..."
                        class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all h-[48px]"
                    />
                </div>
                
                <div class="flex items-center gap-3 w-full md:w-auto">
                    <select
                        id="type-filter"
                        class="bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-500 shadow-sm flex-grow md:flex-grow-0 cursor-pointer h-[48px]"
                    >
                        <option value="All">All Platforms</option>
                    </select>

                    <!-- VIEW MODE TOGGLE -->
                    <div class="flex items-center border border-slate-200 rounded-xl overflow-hidden shadow-sm shrink-0 bg-white h-[48px]">
                        <button id="grid-view-btn" class="w-12 h-full flex items-center justify-center transition-all outline-none">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                        </button>
                        <button id="list-view-btn" class="w-12 h-full flex items-center justify-center transition-all outline-none border-l border-slate-100">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><circle cx="3" cy="6" r="1" fill="currentColor"></circle><circle cx="3" cy="12" r="1" fill="currentColor"></circle><circle cx="3" cy="18" r="1" fill="currentColor"></circle></svg>
                        </button>
                    </div>
                </div>
            </div>

            <div class="flex flex-wrap gap-2 items-center">
                <span class="text-sm font-semibold text-slate-500 mr-2 flex items-center gap-1">
                    <i data-lucide="filter" class="w-4 h-4"></i> Categories:
                </span>
                <div id="category-filters" class="flex flex-wrap gap-2">
                    <!-- Categories injected here -->
                </div>
            </div>
        </div>

        <div class="mb-4 text-sm text-slate-500 flex justify-between items-center font-medium">
            <span id="results-count">Found 0 assistants</span>
            <button onclick="fetchData()" class="flex items-center gap-1.5 hover:text-blue-600 transition-colors font-semibold text-xs uppercase tracking-wider">
                <i data-lucide="refresh-cw" class="w-3 h-3" id="refresh-icon"></i>
                Refresh Data
            </button>
        </div>

        <!-- Content Area -->
        <div id="grid-container" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Grid cards injected here -->
        </div>

        <div id="list-container" class="hidden bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-slate-50 border-b border-slate-200">
                        <tr>
                            <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Assistant</th>
                            <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Category</th>
                            <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Platform</th>
                            <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider text-right">Status</th>
                        </tr>
                    </thead>
                    <tbody id="list-tbody" class="divide-y divide-slate-100">
                        <!-- Table rows injected here -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- No Results -->
        <div id="no-results" class="hidden text-center py-20 bg-white rounded-2xl border-2 border-dashed border-slate-200 shadow-sm">
            <i data-lucide="search" class="w-12 h-12 text-slate-300 mx-auto mb-4" id="no-results-icon"></i>
            <h3 class="text-xl font-bold text-slate-900">No matches found</h3>
            <p class="text-slate-500 mt-2">Try adjusting your search or category filters.</p>
            <button onclick="resetFilters()" class="mt-6 bg-blue-600 text-white px-6 py-2 rounded-xl font-semibold hover:bg-blue-700 transition-colors shadow-lg shadow-blue-200">
                Reset Filters
            </button>
        </div>

        <footer class="mt-12 text-center text-slate-400 text-sm pb-8">
            <p>© <span id="year"></span> District AI Assistant Library</p>
        </footer>
    </div>

    <script>
        // Configuration - UPDATED TO NEW SPREADSHEET URL
        const SHEET_CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vSKhtq7v2Se3nI_ZJox4oPw9uEQWi66Ar683WZa9ba3oNK31SK5tytLqfTIHcE-8AFa6EWGccTuzoYe/pub?gid=0&single=true&output=csv";
        const SHARE_URL = "https://docs.google.com/forms/d/1UNjmdkA__3SQD0JGz_JPVRJYlc2CVPxMGXFazaC-gfE/viewform?edit_requested=true";
        
        // State
        let assistants = [];
        let searchQuery = "";
        let selectedCategory = "Featured"; 
        let selectedType = "All";
        let viewMode = "grid";

        // DOM Elements
        const loadingScreen = document.getElementById('loading-screen');
        const errorContainer = document.getElementById('error-container');
        const errorMessage = document.getElementById('error-message');
        const gridContainer = document.getElementById('grid-container');
        const listContainer = document.getElementById('list-container');
        const listTbody = document.getElementById('list-tbody');
        const searchInput = document.getElementById('search-input');
        const typeFilter = document.getElementById('type-filter');
        const categoryFilters = document.getElementById('category-filters');
        const gridBtn = document.getElementById('grid-view-btn');
        const listBtn = document.getElementById('list-view-btn');
        const resultsCount = document.getElementById('results-count');
        const noResults = document.getElementById('no-results');
        const refreshIcon = document.getElementById('refresh-icon');

        document.getElementById('year').textContent = new Date().getFullYear();

        function safeRefreshIcons() {
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            } else {
                setTimeout(safeRefreshIcons, 100);
            }
        }

        function parseCSV(text) {
            if (!text || text.trim().length === 0) return [];
            const lines = text.split(/\r?\n/).filter(line => line.trim() !== "");
            if (lines.length < 1) return [];

            function parseLine(line) {
                const result = [];
                let cur = "";
                let inQuotes = false;
                for (let i = 0; i < line.length; i++) {
                    const char = line[i];
                    if (char === '"' && line[i + 1] === '"') {
                        cur += '"';
                        i++;
                    } else if (char === '"') {
                        inQuotes = !inQuotes;
                    } else if (char === ',' && !inQuotes) {
                        result.push(cur.trim());
                        cur = "";
                    } else {
                        cur += char;
                    }
                }
                result.push(cur.trim());
                return result;
            }

            const headers = parseLine(lines[0]).map(h => h.toLowerCase().trim());
            
            return lines.slice(1).map((line, index) => {
                const values = parseLine(line);
                const entry = {};
                headers.forEach((header, i) => { entry[header] = values[i] || ""; });
                return {
                    id: entry.id || `row-${index}`,
                    name: entry.name || "Untitled Assistant",
                    type: entry.type || "Other",
                    status: (entry.status || "Live").charAt(0).toUpperCase() + (entry.status || "Live").slice(1).toLowerCase(),
                    category: entry.category || "General",
                    url: entry.url || "#",
                    description: entry.description || ""
                };
            }).filter(item => item.name !== "Untitled Assistant" || item.description !== "");
        }

        async function fetchData() {
            loadingScreen.style.display = 'flex';
            loadingScreen.style.opacity = '1';
            errorContainer.classList.add('hidden');
            refreshIcon.classList.add('animate-spin');

            // Force a fresh request with a direct cache-buster
            const cacheBuster = `&t=${Date.now()}`;
            const finalSourceUrl = SHEET_CSV_URL + cacheBuster;

            const strategies = [
                { 
                    name: 'Primary Proxy (AllOrigins JSON)', 
                    type: 'json', 
                    url: `https://api.allorigins.win/get?url=${encodeURIComponent(finalSourceUrl)}` 
                },
                { 
                    name: 'Secondary Proxy (CORSProxy)', 
                    type: 'text', 
                    url: `https://corsproxy.io/?${encodeURIComponent(finalSourceUrl)}` 
                },
                { 
                    name: 'Direct Browser Request', 
                    type: 'text', 
                    url: finalSourceUrl 
                }
            ];

            let success = false;
            let finalErrorDetail = "No data received.";

            for (const strategy of strategies) {
                try {
                    console.log(`Connection attempt: ${strategy.name}`);
                    const response = await fetch(strategy.url);
                    
                    if (!response.ok) throw new Error(`Server returned status ${response.status}`);
                    
                    let csvText = "";
                    if (strategy.type === 'json') {
                        const json = await response.json();
                        csvText = json.contents;
                    } else {
                        csvText = await response.text();
                    }

                    const data = parseCSV(csvText);
                    if (data && data.length > 0) {
                        assistants = data;
                        success = true;
                        console.log("Database connected successfully.");
                        break;
                    }
                } catch (e) {
                    finalErrorDetail = e.message;
                    console.error(`${strategy.name} failed:`, e);
                }
            }

            refreshIcon.classList.remove('animate-spin');
            
            if (success) {
                loadingScreen.style.opacity = '0';
                setTimeout(() => { loadingScreen.style.display = 'none'; }, 300);
                updateFiltersUI();
                render();
            } else {
                loadingScreen.style.display = 'none';
                errorContainer.classList.remove('hidden');
                errorMessage.textContent = `Error: ${finalErrorDetail}. This usually means your current network or browser is blocking the data request. Try checking the "Publish to Web" settings in your Google Sheet one more time.`;
            }
        }

        function updateFiltersUI() {
            const baseCategories = [...new Set(assistants.map(a => a.category))].filter(c => c !== "Featured" && c !== "").sort();
            const uniqueCategories = ["All", "Featured", ...baseCategories];

            categoryFilters.innerHTML = uniqueCategories.map(cat => `
                <button 
                    onclick="setCategory('${cat}')"
                    class="category-pill px-4 py-1.5 rounded-full text-sm font-medium transition-all ${selectedCategory === cat ? 'bg-blue-600 text-white shadow-md' : 'bg-white text-slate-600 border border-slate-200 hover:border-blue-300 hover:bg-blue-50'}"
                    data-category="${cat}"
                >
                    ${cat}
                </button>
            `).join('');

            const uniqueTypes = ["All", ...new Set(assistants.map(a => a.type))].filter(t => t !== "").sort();
            typeFilter.innerHTML = uniqueTypes.map(t => `
                <option value="${t}" ${selectedType === t ? 'selected' : ''}>${t === 'All' ? 'All Platforms' : t}</option>
            `).join('');
        }

        function getPlatformIconHTML(type) {
            const normalized = type.toLowerCase();
            if (normalized.includes("gpt")) {
                return `<div class="w-8 h-8 rounded bg-emerald-600 flex items-center justify-center text-white shrink-0 shadow-sm">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" /></svg>
                </div>`;
            } else if (normalized.includes("gemini") || normalized.includes("gem")) {
                return `<div class="w-8 h-8 rounded bg-blue-500 flex items-center justify-center text-white shrink-0 shadow-sm">
                    <i data-lucide="sparkles" class="w-5 h-5 fill-current"></i>
                </div>`;
            } else if (normalized.includes("notebook")) {
                return `<div class="w-8 h-8 rounded bg-purple-600 flex items-center justify-center text-white shrink-0 shadow-sm">
                    <i data-lucide="book-open" class="w-5 h-5"></i>
                </div>`;
            }
            return `<div class="w-8 h-8 rounded bg-slate-400 flex items-center justify-center text-white shrink-0 font-bold text-xs shadow-sm">AI</div>`;
        }

        function render() {
            const filtered = assistants.filter(item => {
                const matchesSearch = searchQuery === "" || 
                    item.name.toLowerCase().includes(searchQuery) || 
                    item.description.toLowerCase().includes(searchQuery);
                const matchesCategory = selectedCategory === "All" || 
                                       (selectedCategory === "Featured" ? item.status === "Featured" : item.category === selectedCategory);
                const matchesType = selectedType === "All" || item.type === selectedType;
                return matchesSearch && matchesCategory && matchesType;
            }).sort((a, b) => a.name.localeCompare(b.name));

            resultsCount.textContent = `Found ${filtered.length} assistant${filtered.length !== 1 ? 's' : ''}`;
            
            if (viewMode === 'grid') {
                gridBtn.className = "w-12 h-full flex items-center justify-center transition-all outline-none bg-blue-600 text-white";
                listBtn.className = "w-12 h-full flex items-center justify-center transition-all outline-none bg-white text-slate-400 hover:text-slate-600";
            } else {
                gridBtn.className = "w-12 h-full flex items-center justify-center transition-all outline-none bg-white text-slate-400 hover:text-slate-600";
                listBtn.className = "w-12 h-full flex items-center justify-center transition-all outline-none bg-blue-600 text-white";
            }

            if (filtered.length === 0) {
                noResults.classList.remove('hidden');
                gridContainer.classList.add('hidden');
                listContainer.classList.add('hidden');
            } else {
                noResults.classList.add('hidden');
                if (viewMode === 'grid') {
                    gridContainer.classList.remove('hidden');
                    listContainer.classList.add('hidden');
                    renderGrid(filtered);
                } else {
                    gridContainer.classList.add('hidden');
                    listContainer.classList.remove('hidden');
                    renderList(filtered);
                }
            }
            safeRefreshIcons();
        }

        function renderGrid(data) {
            gridContainer.innerHTML = data.map(item => `
                <a href="${item.url}" target="_blank" rel="noopener" class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm hover:border-blue-400 hover:shadow-xl hover:-translate-y-1 transition-all group flex flex-col h-full relative">
                    <div class="flex items-start justify-between mb-4">
                        ${getPlatformIconHTML(item.type)}
                        <div class="flex items-center gap-2">
                            <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-md ${getStatusClass(item.status)}">
                                ${item.status}
                            </span>
                            <button onclick="handleShare(event)" class="p-1.5 rounded-md hover:bg-slate-100 text-slate-400 hover:text-blue-600 transition-colors" title="Share / Suggestion">
                                <i data-lucide="share-2" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </div>
                    <div class="flex-grow">
                        <h3 class="font-bold text-lg text-slate-900 group-hover:text-blue-600 transition-colors mb-2 leading-tight">${item.name}</h3>
                        <p class="text-sm text-slate-500 line-clamp-2 mb-4">${item.description}</p>
                    </div>
                    <div class="mt-auto pt-4 border-t border-slate-50 flex items-center justify-between">
                        <span class="text-xs font-medium text-blue-600 bg-blue-50 px-2 py-1 rounded">${item.category}</span>
                        <i data-lucide="external-link" class="w-4 h-4 text-slate-300 group-hover:text-blue-500 transition-colors"></i>
                    </div>
                </a>
            `).join('');
        }

        function renderList(data) {
            listTbody.innerHTML = data.map(item => `
                <tr onclick="window.open('${item.url}', '_blank')" class="hover:bg-blue-50 transition-colors cursor-pointer group">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-4">
                            ${getPlatformIconHTML(item.type)}
                            <div>
                                <div class="font-bold text-slate-900 group-hover:text-blue-600 transition-colors">${item.name}</div>
                                <div class="text-xs text-slate-400 line-clamp-1 max-w-md">${item.description}</div>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <span class="text-xs font-medium text-blue-600 bg-blue-50 px-2 py-1 rounded">${item.category}</span>
                    </td>
                    <td class="px-6 py-4">
                        <span class="text-sm text-slate-600">${item.type}</span>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <div class="flex items-center justify-end gap-3">
                            <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-md ${getStatusClass(item.status)}">${item.status}</span>
                            <button onclick="handleShare(event)" class="p-1.5 rounded-md hover:bg-white text-slate-400 hover:text-blue-600 transition-colors">
                                <i data-lucide="share-2" class="w-4 h-4"></i>
                            </button>
                            <i data-lucide="chevron-right" class="w-4 h-4 text-slate-300 group-hover:text-blue-500 transition-colors"></i>
                        </div>
                    </td>
                </tr>
            `).join('');
        }

        function getStatusClass(status) {
            const s = status.toLowerCase();
            if (s === 'featured') return 'bg-purple-100 text-purple-700';
            if (s === 'live') return 'bg-emerald-100 text-emerald-700';
            return 'bg-amber-100 text-amber-700';
        }

        searchInput.addEventListener('input', (e) => {
            searchQuery = e.target.value.toLowerCase().trim();
            render();
        });

        typeFilter.addEventListener('change', (e) => {
            selectedType = e.target.value;
            render();
        });

        function setCategory(cat) {
            selectedCategory = cat;
            document.querySelectorAll('.category-pill').forEach(btn => {
                if (btn.dataset.category === cat) {
                    btn.className = "category-pill px-4 py-1.5 rounded-full text-sm font-medium transition-all bg-blue-600 text-white shadow-md";
                } else {
                    btn.className = "category-pill px-4 py-1.5 rounded-full text-sm font-medium transition-all bg-white text-slate-600 border border-slate-200 hover:border-blue-300 hover:bg-blue-50";
                }
            });
            render();
        }

        gridBtn.addEventListener('click', () => {
            viewMode = 'grid';
            render();
        });

        listBtn.addEventListener('click', () => {
            viewMode = 'list';
            render();
        });

        function handleShare(e) {
            e.preventDefault();
            e.stopPropagation();
            window.open(SHARE_URL, '_blank');
        }

        function resetFilters() {
            searchQuery = "";
            selectedCategory = "Featured";
            selectedType = "All";
            searchInput.value = "";
            typeFilter.value = "All";
            setCategory("Featured");
        }

        window.onload = fetchData;
    </script>
</body>
</html>
